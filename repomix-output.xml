<file path="app/api/ping/route.js">
export async function GET() {
    let hasKv = false;
    try {
        const { getCloudflareContext } = await import("@opennextjs/cloudflare");
        const { env } = await getCloudflareContext();
        hasKv = !!env?.STOCK_DATA;
    } catch { }

    return new Response(JSON.stringify({
        ok: true,
        time: new Date().toISOString(),
        env: {
            NEXT_RUNTIME: typeof process !== 'undefined' ? process.env.NEXT_RUNTIME : 'undefined',
            HAS_STOCK_KV: hasKv,
        }
    }), {
        headers: { 'Content-Type': 'application/json' }
    });
}
</file>

<file path="app/api/user/list/route.js">
import { NextResponse } from 'next/server';
import { getAllUserIds } from '@/lib/storage/userRepo';
import { isAdminAuthorized } from '@/lib/storage/authRepo';

export async function GET(request) {
    if (!(await isAdminAuthorized(request))) {
        return NextResponse.json({ error: 'Unauthorized' }, { status: 403 });
    }

    // 从 D1 获取所有用户 ID
    const userIds = await getAllUserIds();

    // 排除 admin 账号
    const filtered = userIds.filter(id => id !== 'admin');

    return NextResponse.json(filtered);
}
